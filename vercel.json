    },
    {
      "source": "/db/push-state.json",
      "destination": "/db/metadata/notifications/push-state.json"
    },
    {
      "source": "/db/push-subscriptions.json",
      "destination": "/db/metadata/notifications/push-subscriptions.json"
    },
    {
      "source": "/db/repeat-computing.json",
      "destination": "/db/timetables/repeat-computing.json"

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/css/:path*",
      "destination": "/web/css/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/web/js/:path*"
    },
    {
      "source": "/components/:path*",
      "destination": "/web/components/:path*"
    },
    {
      "source": "/modals/:path*",
      "destination": "/web/modals/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/web/assets/:path*"
    },
    {
      "source": "/icons/:path*",
      "destination": "/web/icons/:path*"
    },
    {
      "source": "/manifest.json",
      "destination": "/web/manifest.json"
    },
    {
      "source": "/service-worker.js",
      "destination": "/web/service-worker.js"
    },
    {
      "source": "/db/22.json",
      "destination": "/db/students/22.json"
    },
    {
      "source": "/db/23.json",
      "destination": "/db/students/23.json"
    },
    {
      "source": "/db/24.json",
      "destination": "/db/students/24.json"
    },
    {
      "source": "/db/25.json",
      "destination": "/db/students/25.json"
    },
    {
      "source": "/db/26.json",
      "destination": "/db/students/26.json"
    },
    {
      "source": "/db/class-notify-state.json",
      "destination": "/db/metadata/notifications/class-notify-state.json"
    },
    {
      "source": "/db/exam-schedule-business.json",
      "destination": "/db/exams/business.json"
    },
    {
      "source": "/db/exam-schedule-computing.json",
      "destination": "/db/exams/computing.json"
    },
    {
      "source": "/db/exam-schedule-engineering.json",
      "destination": "/db/exams/engineering.json"
    },
    {
      "source": "/db/faculty_data.json",
      "destination": "/db/faculty/data.json"
    },
    {
      "source": "/db/leaderboard.json",
      "destination": "/db/games/leaderboards/compiler-run.json"
    },
    {
      "source": "/db/leaderboard-duck-hunter.json",
      "destination": "/db/games/leaderboards/duck-hunter.json"
